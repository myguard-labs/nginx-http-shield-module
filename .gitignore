# Build output from tools/ci-build.sh
.build/

# Test::Nginx scratch
t/servroot/
t/*.t.tmp

# Ban unit harness binary (built by t/run-ban-unit.sh)
t/ban_unit

# Fuzz build outputs (keep sources, corpus seeds, and fuzz.dict)
fuzz/fuzz_scan
fuzz/crash-*
fuzz/corpus-min/
fuzz/leak-*
fuzz/oom-*
fuzz/timeout-*

# libFuzzer corpus growth: every input it keeps is written back to the corpus
# dir under its SHA1. The 16 hand-written seeds are word-named and stay tracked;
# these accumulate by the hundred on every run and must never be committed.
# Both layouts occur: -artifact_prefix/corpus arg points at fuzz/corpus/ in CI,
# at fuzz/corpus/fuzz_scan/ locally, so ignore the SHA1 form in both.
fuzz/corpus/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]
fuzz/corpus/fuzz_scan/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]

