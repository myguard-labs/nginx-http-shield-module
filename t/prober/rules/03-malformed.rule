# Malformed and hostile request framing. These are the cases a client library
# will not emit -- libcurl normalizes away exactly the malformation under test,
# which is why the prober writes raw bytes.
#
# The assertion for most of these is deliberately weak: what matters is that
# the worker SURVIVES and keeps serving, which the following case proves by
# getting a valid probe response. A crash here shows up as a connection error
# on the next case, not as a wrong status code.

name    request with no Host header
send    GET /guarded?id=1+union+select+1,2,3-- HTTP/1.1\r\n
send    Connection: close\r\n\r\n
expect  status=400

name    absolute-form request target
send    GET http://prober/guarded?id=1+union+select+1,2,3-- HTTP/1.1\r\n
send    Host: prober\r\nConnection: close\r\n\r\n
expect  status=403

name    duplicate Content-Type headers, payload in the body
send    POST /body HTTP/1.1\r\n
send    Host: prober\r\n
send    Content-Type: application/octet-stream\r\n
send    Content-Type: text/plain\r\n
send    Content-Length: 35\r\n
send    Connection: close\r\n\r\n
send    id=1+union+select+1,2,3--&x=1234567
expect  status=403

name    percent-encoded payload is decoded before matching
send    GET /guarded?id=1+%75nion+%73elect+1,2,3-- HTTP/1.1\r\n
send    Host: prober\r\nConnection: close\r\n\r\n
expect  status=403

name    double-encoded payload does NOT match, decode happens once only
send    GET /guarded?id=1+%2575nion+%2573elect+1,2,3-- HTTP/1.1\r\n
send    Host: prober\r\nConnection: close\r\n\r\n
expect  status=502

name    NUL byte inside the query string
send    GET /guarded?id=1\x00union+select+1,2,3-- HTTP/1.1\r\n
send    Host: prober\r\nConnection: close\r\n\r\n
expect  status=400

name    bare LF line endings instead of CRLF
send    GET /guarded?id=1+union+select+1,2,3-- HTTP/1.1\n
send    Host: prober\nConnection: close\n\n
expect  status=403

# A large-but-legal header stays under large_client_header_buffers (4 8k by
# default), so it must be parsed normally and reach the upstream -- 502 from the
# dead proxy target. This is the control for the case below it.
name    large but legal header value is parsed normally
send    GET /guarded HTTP/1.1\r\n
send    Host: prober\r\n
send    X-Filler:
repeat  40 AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
send    \r\nConnection: close\r\n\r\n
expect  status=502

# 128 * 64 = 8192 bytes of value, which is the whole default buffer before the
# request line and the other headers are even counted, so nginx and angie both
# reject the request at the parser with 400. Asserting 502 here (as this case
# did while its filler was only 196 bytes long) would mean the case never
# reached the limit it was named after.
name    oversized header value is rejected by the parser
send    GET /guarded HTTP/1.1\r\n
send    Host: prober\r\n
send    X-Filler:
repeat  128 AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
send    \r\nConnection: close\r\n\r\n
expect  status=400

# The worker must still be alive and the zone still coherent after everything
# above. If any earlier case killed it, this one fails on connect.
name    worker survives the malformed batch and the zone is still coherent
send    GET /__probe HTTP/1.1\r\n
send    Host: prober\r\nConnection: close\r\n\r\n
expect  status=200
probe   zone.present == true
probe   flavor ~ ngi
